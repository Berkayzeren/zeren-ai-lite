# ENV EXAMPLE
# Bu dosya sistem için gerekli ortam değişkenlerinin şablonudur.
# .env olarak kopyalayın ve gerçek değerleri girin.

# Proje Ayarları
PROJECT_NAME="Zeren AI Lite"
DEBUG=True
ENVIRONMENT="development" # development, production

# API Anahtarları (Lite versiyonda bu anahtarlar sadece şemadır)
STOCK_API_KEY="your_api_key_here"
CRYPTO_API_KEY="your_api_key_here"
SENTIMENT_API_KEY="your_news_api_key_here"  # Örn: NewsAPI, CryptoPanic vb.

# Risk Yönetimi Parametreleri
MAX_POSITION_SIZE=0.10 # Portföyün %10'u
KELLY_FRACTION=0.5
RISK_THRESHOLD="conservative" # conservative, moderate, aggressive

# Dashboard Ayarları
NEXT_PUBLIC_API_URL="http://localhost:8000"
LANG="tr" # en, tr
